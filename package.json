    "clsx": "2.1.1",
    "next": "^16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "tailwind-merge": "3.6.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
